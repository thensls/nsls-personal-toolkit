# Personal Productivity Toolkit — Environment Variables
#
# EASIEST WAY: Just say "/setup" in Claude Code and it fills this in for you.
#
# Or copy this file to .env and fill in manually:
#   cp .env.example .env
#

# Your Slack user ID
# (Find it: click your profile pic in Slack → Profile → ⋮ → Copy member ID)
SLACK_USER_ID=

# Your Asana workspace and user GIDs
# (/setup auto-detects these if you have Asana connected)
ASANA_WORKSPACE_GID=
ASANA_USER_GID=

# Obsidian vault path (used by /open-day, /close-day, /close-week, /log)
# Common locations:
#   Local: ~/Obsidian/[initials]/
#   iCloud: ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/[initials]/
OBSIDIAN_VAULT_PATH=

# Airtable personal access token (only needed for /person-intelligence)
# Get one at: airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=

# NSLS Airtable base IDs — these are already correct for all NSLS employees.
# Non-NSLS users: replace with your own base IDs.
PEOPLE_OPS_BASE_ID=appnXPTu01esWWbrK
SLT_BASE_ID=appHDEHQA4bvlWwQq
